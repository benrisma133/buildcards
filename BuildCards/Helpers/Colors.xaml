<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ACCENT COLORS -->
    <Color x:Key="AccentColor">#3B82F6</Color>
    <Color x:Key="AccentHoverColor">#2563EB</Color>
    <Color x:Key="AccentPressedColor">#1D4ED8</Color>
    <Color x:Key="AccentLightColor">#1E3A5F</Color>

    <SolidColorBrush x:Key="AccentBrush"        Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"   Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush"   Color="{StaticResource AccentLightColor}"/>

    <!-- BACKGROUND COLORS -->
    <Color x:Key="AppBackgroundColor">#0F0F1A</Color>
    <Color x:Key="SidebarBackgroundColor">#1A1A2E</Color>
    <Color x:Key="CardBackgroundColor">#1E1E2E</Color>
    <Color x:Key="CardHoverBackgroundColor">#252538</Color>
    <Color x:Key="InputBackgroundColor">#252538</Color>
    <Color x:Key="HeaderBackgroundColor">#16162A</Color>
    <Color x:Key="PopupBackgroundColor">#1E1E2E</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush"       Color="{StaticResource AppBackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush"   Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush"      Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardHoverBackgroundBrush" Color="{StaticResource CardHoverBackgroundColor}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush"     Color="{StaticResource InputBackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush"    Color="{StaticResource HeaderBackgroundColor}"/>
    <SolidColorBrush x:Key="PopupBackgroundBrush"     Color="{StaticResource PopupBackgroundColor}"/>

    <!-- TEXT COLORS -->
    <Color x:Key="TextPrimaryColor">#F1F5F9</Color>
    <Color x:Key="TextSecondaryColor">#94A3B8</Color>
    <Color x:Key="TextMutedColor">#64748B</Color>
    <Color x:Key="TextPlaceholderColor">#475569</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"       Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextPlaceholderBrush" Color="{StaticResource TextPlaceholderColor}"/>
    <SolidColorBrush x:Key="TextOnAccentBrush"    Color="{StaticResource TextOnAccentColor}"/>

    <!-- BORDER COLORS -->
    <Color x:Key="BorderDefaultColor">#2D2D44</Color>
    <Color x:Key="BorderHoverColor">#3B82F6</Color>
    <Color x:Key="BorderFocusColor">#3B82F6</Color>
    <Color x:Key="BorderErrorColor">#EF4444</Color>

    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefaultColor}"/>
    <SolidColorBrush x:Key="BorderHoverBrush"   Color="{StaticResource BorderHoverColor}"/>
    <SolidColorBrush x:Key="BorderFocusBrush"   Color="{StaticResource BorderFocusColor}"/>
    <SolidColorBrush x:Key="BorderErrorBrush"   Color="{StaticResource BorderErrorColor}"/>

    <!-- STATUS COLORS -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="SuccessLightColor">#064E3B</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="WarningLightColor">#78350F</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="ErrorLightColor">#7F1D1D</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="InfoLightColor">#1E3A5F</Color>

    <SolidColorBrush x:Key="SuccessBrush"      Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLightColor}"/>
    <SolidColorBrush x:Key="WarningBrush"      Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}"/>
    <SolidColorBrush x:Key="ErrorBrush"        Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="ErrorLightBrush"   Color="{StaticResource ErrorLightColor}"/>
    <SolidColorBrush x:Key="InfoBrush"         Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoLightBrush"    Color="{StaticResource InfoLightColor}"/>

    <!-- SIDEBAR MENU COLORS -->
    <Color x:Key="MenuNormalColor">#1A1A2E</Color>
    <Color x:Key="MenuHoverColor">#252538</Color>
    <Color x:Key="MenuActiveColor">#1E3A5F</Color>
    <Color x:Key="MenuActiveForegroundColor">#3B82F6</Color>
    <Color x:Key="MenuNormalForegroundColor">#F1F5F9</Color>

    <SolidColorBrush x:Key="MenuNormalBrush"           Color="{StaticResource MenuNormalColor}"/>
    <SolidColorBrush x:Key="MenuHoverBrush"            Color="{StaticResource MenuHoverColor}"/>
    <SolidColorBrush x:Key="MenuActiveBrush"           Color="{StaticResource MenuActiveColor}"/>
    <SolidColorBrush x:Key="MenuActiveForegroundBrush" Color="{StaticResource MenuActiveForegroundColor}"/>
    <SolidColorBrush x:Key="MenuNormalForegroundBrush" Color="{StaticResource MenuNormalForegroundColor}"/>

    <!-- SCROLLBAR -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#2D2D44"/>
    <SolidColorBrush x:Key="ScrollTrackBrush" Color="Transparent"/>

    <!-- SHADOW -->
    <Color x:Key="ShadowColor">#000000</Color>

</ResourceDictionary>