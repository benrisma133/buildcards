<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- ACCENT -->
	<SolidColorBrush x:Key="AccentBrush"        Color="#3B82F6"/>
	<SolidColorBrush x:Key="AccentHoverBrush"   Color="#2563EB"/>
	<SolidColorBrush x:Key="AccentPressedBrush" Color="#1D4ED8"/>
	<SolidColorBrush x:Key="AccentLightBrush"   Color="#1E3A5F"/>

	<!-- BACKGROUND -->
	<SolidColorBrush x:Key="AppBackgroundBrush"       Color="#0F0F1A"/>
	<SolidColorBrush x:Key="SidebarBackgroundBrush"   Color="#1A1A2E"/>
	<SolidColorBrush x:Key="CardBackgroundBrush"      Color="#1E1E2E"/>
	<SolidColorBrush x:Key="CardHoverBackgroundBrush" Color="#252538"/>
	<SolidColorBrush x:Key="InputBackgroundBrush"     Color="#252538"/>
	<SolidColorBrush x:Key="HeaderBackgroundBrush"    Color="#16162A"/>
	<SolidColorBrush x:Key="PopupBackgroundBrush"     Color="#1E1E2E"/>

	<!-- TEXT -->
	<SolidColorBrush x:Key="TextPrimaryBrush"     Color="#F1F5F9"/>
	<SolidColorBrush x:Key="TextSecondaryBrush"   Color="#94A3B8"/>
	<SolidColorBrush x:Key="TextMutedBrush"       Color="#64748B"/>
	<SolidColorBrush x:Key="TextPlaceholderBrush" Color="#475569"/>
	<SolidColorBrush x:Key="TextOnAccentBrush"    Color="#FFFFFF"/>

	<!-- BORDER -->
	<SolidColorBrush x:Key="BorderDefaultBrush" Color="#2D2D44"/>
	<SolidColorBrush x:Key="BorderHoverBrush"   Color="#3B82F6"/>
	<SolidColorBrush x:Key="BorderFocusBrush"   Color="#3B82F6"/>
	<SolidColorBrush x:Key="BorderErrorBrush"   Color="#EF4444"/>

	<!-- STATUS -->
	<SolidColorBrush x:Key="SuccessBrush"      Color="#10B981"/>
	<SolidColorBrush x:Key="SuccessLightBrush" Color="#064E3B"/>
	<SolidColorBrush x:Key="WarningBrush"      Color="#F59E0B"/>
	<SolidColorBrush x:Key="WarningLightBrush" Color="#78350F"/>
	<SolidColorBrush x:Key="ErrorBrush"        Color="#EF4444"/>
	<SolidColorBrush x:Key="ErrorLightBrush"   Color="#7F1D1D"/>
	<SolidColorBrush x:Key="InfoBrush"         Color="#3B82F6"/>
	<SolidColorBrush x:Key="InfoLightBrush"    Color="#1E3A5F"/>

	<!-- MENU -->
	<SolidColorBrush x:Key="MenuNormalBrush"           Color="#1A1A2E"/>
	<SolidColorBrush x:Key="MenuHoverBrush"            Color="#252538"/>
	<SolidColorBrush x:Key="MenuActiveBrush"           Color="#1E3A5F"/>
	<SolidColorBrush x:Key="MenuActiveForegroundBrush" Color="#3B82F6"/>
	<SolidColorBrush x:Key="MenuNormalForegroundBrush" Color="#F1F5F9"/>

	<!-- SCROLLBAR -->
	<SolidColorBrush x:Key="ScrollThumbBrush" Color="#2D2D44"/>
	<SolidColorBrush x:Key="ScrollTrackBrush" Color="Transparent"/>

	<!-- SHADOW -->
	<Color x:Key="ShadowColor">#000000</Color>

</ResourceDictionary>