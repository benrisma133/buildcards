<UserControl x:Class="BuildCards.Controls.Cards.FlipCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">

    <Grid x:Name="CardContainer"
          MouseDown="CardContainer_MouseDown">

        <!-- Transform -->
        <Grid.RenderTransform>
            <ScaleTransform x:Name="CardScale" ScaleX="1"/>
        </Grid.RenderTransform>

        <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>

        <!-- FRONT -->
        <Grid x:Name="FrontCard">
            <Border Background="LightBlue" Padding="20" CornerRadius="10">
                <TextBlock Text="FRONT" FontSize="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- BACK -->
        <Grid x:Name="BackCard" Visibility="Collapsed">
            <!-- نقلب المحتوى باش يصلح -->
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="-1"/>
            </Grid.RenderTransform>

            <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>

            <Border Background="LightCoral" Padding="20" CornerRadius="10">
                <TextBlock Text="BACK" FontSize="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>

    </Grid>
</UserControl>