<UserControl x:Class="BuildCards.Controls.Cards.EnrollmentCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BuildCards.Controls.Cards"
             mc:Ignorable="d" 
             x:Name="Root">

    <Border x:Name="CardBorder"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="20"
            HorizontalAlignment="Stretch"
            Margin="0"
            RenderTransformOrigin="0.5,0.5">

        <Border.RenderTransform>
            <TranslateTransform x:Name="CardTranslate"/>
        </Border.RenderTransform>

        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                         Storyboard.TargetProperty="Y"
                                         To="-2"
                                         Duration="0:0:0.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="CardTranslate"
                             Storyboard.TargetProperty="Y"
                             To="0"
                             Duration="0:0:0.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Border.Effect>
            <DropShadowEffect x:Name="CardShadow"
                              BlurRadius="15"
                              ShadowDepth="0"
                              Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar Circle -->
                <Border Grid.Column="0"
                        Width="46"
                        Height="46"
                        CornerRadius="23"
                        Background="{DynamicResource AccentLightBrush}"
                        Margin="0,0,14,0">

                    <TextBlock x:Name="AvatarText"
                               Text="AV"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>

                </Border>

                <!-- Name + Course -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    
                    <!-- Name -->
                    <TextBlock x:Name="FullNameText"
                               Text="Ismail Benrahhal"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Course -->
                    <TextBlock x:Name="CourseText"
                               Text="Entity Framework"
                               FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,3,0,0"/>

                </StackPanel>

            </Grid>

            <!-- ROW 2: Divider -->
            <Border Grid.Row="1"
                    Height="1"
                    Background="{DynamicResource BorderDefaultBrush}"
                    VerticalAlignment="Center"/>

            <!-- ROW 3: Progress label + Grade + Enrollment date  -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- COLUMN 0: Progress -->
                <StackPanel Grid.Column="0">
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Progress"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock x:Name="ProgressText"
                                   Grid.Column="1"
                                   FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </Grid>

                    <!-- Progress Bar -->
                    <Grid Margin="0,3,0,0">
                        <!-- Background track -->
                        <Border Height="8"
                                Background="{DynamicResource BorderDefaultBrush}"
                                CornerRadius="4"/>
                        <!-- Filled portion -->
                        <Border x:Name="ProgressFill"
                                Height="8"
                                Background="{DynamicResource AccentBrush}"
                                CornerRadius="4"
                                HorizontalAlignment="Left"/>
                    </Grid>

                </StackPanel>

                <!-- COLUMN 1: Grade -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Grade"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                    <TextBlock x:Name="GradeText"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- COLUMN 2: Enrollment date -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Enrollment date"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                    <TextBlock x:Name="EnrollmentDateText"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

            </Grid>
            
            <!-- ROW 4: Divider -->
            <Border Grid.Row="3"
                    Height="1"
                    Background="{DynamicResource BorderDefaultBrush}"
                    VerticalAlignment="Center"/>


        </Grid>

    </Border>
    
</UserControl>
